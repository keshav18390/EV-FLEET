# ===== LLM PROVIDER CONFIG =====
# Choose ONE provider: openai | groq | openrouter | gemini | claude
LLM_PROVIDER=groq

# Set the matching API key for whichever provider you chose above
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# Optional overrides (leave blank to use provider defaults)
LLM_BASE_URL=
LLM_MODEL_NAME=

# ===== AUTH =====
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== DATABASE =====
DATABASE_URL=sqlite:///./fleet.db

# ===== APP =====
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
